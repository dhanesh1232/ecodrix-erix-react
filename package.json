{
  "name": "@ecodrix/erix-react",
  "version": "0.2.1",
  "description": "Complete Ecodrix React SDK — RichText Editor, CRM, Analytics, WhatsApp, Marketing, and Meetings — all in one embeddable package.",
  "author": "ECODrIx Team <contact@ecodrix.com>",
  "license": "MIT",
  "homepage": "https://ecodrix.com",
  "private": false,
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.js",
  "types": "./dist/types/index.d.ts",
  "unpkg": "./dist/umd/index.iife.js",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "keywords": [
    "ecodrix",
    "crm",
    "whatsapp",
    "richtext",
    "editor",
    "dashboard",
    "analytics",
    "react",
    "sdk"
  ],
  "exports": {
    ".": {
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/umd/index.iife.js"
    },
    "./styles": {
      "import": "./dist/es/index.css",
      "require": "./dist/cjs/index.css",
      "default": "./dist/umd/index.css"
    },
    "./crm": {
      "import": "./dist/es/crm.js",
      "require": "./dist/cjs/crm.cjs"
    },
    "./analytics": {
      "import": "./dist/es/analytics.js",
      "require": "./dist/cjs/analytics.cjs"
    },
    "./whatsapp": {
      "import": "./dist/es/whatsapp.js",
      "require": "./dist/cjs/whatsapp.cjs"
    },
    "./marketing": {
      "import": "./dist/es/marketing.js",
      "require": "./dist/cjs/marketing.cjs"
    },
    "./meetings": {
      "import": "./dist/es/meetings.js",
      "require": "./dist/cjs/meetings.cjs"
    },
    "./dashboard": {
      "import": "./dist/es/dashboard.js",
      "require": "./dist/cjs/dashboard.cjs"
    },
    "./editor": {
      "import": "./dist/es/editor.js",
      "require": "./dist/cjs/editor.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build:dev": "next build --webpack",
    "build": "pnpm run prepublishOnly",
    "build:lib": "rm -rf dist && tsup --tsconfig tsconfig.build.json",
    "prepublishOnly": "pnpm run build:final",
    "build:types": "api-extractor run --local",
    "build:final": "pnpm run build:lib && pnpm run build:types",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@gsap/react": ">=2.0.0",
    "framer-motion": ">=12.0.0",
    "gsap": ">=3.0.0",
    "next": ">=16.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "recharts": ">=2.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ecodrix/erix-api": "^1.3.4",
    "@radix-ui/react-avatar": "^1.1.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.18.0",
    "grapesjs": "^0.22.15",
    "grapesjs-preset-newsletter": "^1.0.2",
    "lucide-react": "^0.552.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-color": "^2.19.3",
    "react-icons": "^5.6.0",
    "react-phone-number-input": "^3.4.16",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@gsap/react": "^2.1.2",
    "@microsoft/api-extractor": "^7.54.0",
    "@types/node": "^20",
    "@types/react": "^19.2.2",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "next": "^16.2.3",
    "postcss": "^8.5.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
